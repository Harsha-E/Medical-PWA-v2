rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity Check
    match /test/connection {
      allow read: if true;
    }

    // 2. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['userId', 'name', 'email'])
        && incoming().keys().size() <= 10
        && incoming().role == 'user' // Force user role
        && incoming().userId == userId;
      allow update: if (isOwner(userId) || isAdmin())
        && isValidUser(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'bloodType', 'emergencyContact', 'birthYear', 'conditions', 'allergies'])
          || isAdmin()
        );
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() <= 100
        && (data.bloodType == null || (data.bloodType is string && data.bloodType.size() <= 5))
        && (data.email is string && data.email.size() <= 100);
    }

    // 3. Medications
    match /medications/{medicationId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(medicationId)
        && isValidMedication(incoming())
        && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin())
        && isValidMedication(incoming())
        && incoming().userId == existing().userId; // Immutable owner
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    function isValidMedication(data) {
      return data.name is string && data.name.size() <= 100
        && data.dosage is string && data.dosage.size() <= 50
        && data.userId is string && data.userId.size() <= 128
        && (data.notes == null || (data.notes is string && data.notes.size() <= 1000));
    }

    // 4. Appointments
    match /appointments/{appointmentId} {
      allow get, update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(appointmentId)
        && incoming().userId == request.auth.uid
        && incoming().title is string && incoming().title.size() <= 100;
    }

    // 5. Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Console or secure server
    }
  }
}
